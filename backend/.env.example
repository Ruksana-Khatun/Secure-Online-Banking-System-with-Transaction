## Backend environment variables — copy this file to .env and fill in real values

# Server
PORT=5000
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Database
MONGO_URI=mongodb://127.0.0.1:27017/secure_banking

# JWT (REQUIRED — use long random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# Mail (required only if you test OTP emailing)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
APP_FROM_EMAIL=your_email@gmail.com

# ─── Eko API Credentials ──────────────────────────────────────────────────────
# Get these from https://developers.eko.in → Dashboard → API Credentials
EKO_DEVELOPER_KEY=becbbce45f79c6f5109f848acd540567
EKO_AUTH_KEY=d2fe1d99-6298-4af2-8cc5-d97dcf46df30
EKO_INITIATOR_ID=9962981729
EKO_USER_CODE=20810200

# Staging (test) URLs — switch to prod URLs when going live
EKO_BASE_URL=https://staging.eko.in:25004/ekoicici
EKO_PPI_BASE_URL=https://staging.eko.in:25004/ekoapi

EKO_LATLONG=25.309580,83.005692
EKO_TIMEOUT_MS=20000
EKO_RETRIES=2

# ─── PPI Mock Mode ────────────────────────────────────────────────────────────
# true  = use fake/mock responses (no real API calls, no real money)
# false = use real Eko API (requires valid credentials above)
USE_PPI_MOCK=false